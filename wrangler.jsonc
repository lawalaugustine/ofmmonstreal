    "SMTP_FROM_NAME": "Omega Fire Ministries Montreal",
    "SMTP_FROM_EMAIL": "info@ofmmontreal.com",
    "CONTACT_TO": "omegafireministries06@gmail.com,info@ofmmontreal.com"
  }
}
